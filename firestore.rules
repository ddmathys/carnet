rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      // NB : on ne vérifie PAS email_verified — selon le provider, ce claim peut
      // être absent/false dans le token (ce qui bloquait la console admin). Le
      // claim `email` d'un token Firebase est signé par Firebase et ne peut pas
      // être falsifié par le client, donc le check email seul est sûr.
      return isAuth()
          && request.auth.token.email == 'david.mathys24@gmail.com';
    }

    // Accès à un carnet : propriétaire ou collaborateur (sharedWith).
    // Coûte une lecture supplémentaire par opération sur memories — acceptable.
    function canAccessNotebook(notebookId) {
      let nb = get(/databases/$(database)/documents/notebooks/$(notebookId)).data;
      return nb.userId == request.auth.uid
          || request.auth.uid in nb.get('sharedWith', []);
    }

    function ownsChild(childId) {
      return get(/databases/$(database)/documents/children/$(childId)).data.parentId
          == request.auth.uid;
    }

    // ── Notebooks ──────────────────────────────────────────────────────────
    match /notebooks/{notebookId} {
      // Lecture : propriétaire, collaborateur, ou invité par email
      // (l'invité doit pouvoir lister ses invitations pour les résoudre au login)
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || request.auth.uid in resource.data.get('sharedWith', [])
        || (request.auth.token.email != null
            && request.auth.token.email in resource.data.get('invitedEmails', []))
      );

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAuth() && (
        // Propriétaire : tout
        resource.data.userId == request.auth.uid
        // Collaborateur : compteurs uniquement
        || (request.auth.uid in resource.data.get('sharedWith', [])
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['memoriesCount', 'lastMemoryAt', 'updatedAt']))
        // Invité par email : peut convertir son invitation en accès au login
        || (request.auth.token.email != null
            && request.auth.token.email in resource.data.get('invitedEmails', [])
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['sharedWith', 'invitedEmails']))
      );

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Tags (organisation + partage) ───────────────────────────────────────
    // Le partage se pilote ici : les collaborateurs d'un tag sont recopiés dans
    // le champ `sharedWith` de chaque souvenir qui le porte (voir memories).
    match /tags/{tagId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || request.auth.uid in resource.data.get('sharedWith', [])
        || (request.auth.token.email != null
            && request.auth.token.email in resource.data.get('invitedEmails', []))
      );

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        // Invité par email : convertit son invitation en accès à la connexion
        || (request.auth.token.email != null
            && request.auth.token.email in resource.data.get('invitedEmails', [])
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['sharedWith', 'invitedEmails']))
      );

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Memories ────────────────────────────────────────────────────────────
    // Trois portes d'entrée, dans l'ordre du moins cher au plus cher :
    //  1. `userId`     → le propriétaire ;
    //  2. `sharedWith` → un collaborateur, via un tag partagé (champ recopié) ;
    //  3. `notebookId` → repli pour les souvenirs d'avant les tags (une lecture
    //     supplémentaire ; disparaîtra quand tous les comptes seront migrés).
    match /memories/{memoryId} {
      function memberOfMemory(mem) {
        return mem.get('userId', '') == request.auth.uid
            || request.auth.uid in mem.get('sharedWith', [])
            || (mem.get('notebookId', '') != ''
                && canAccessNotebook(mem.notebookId));
      }

      allow read: if isAuth() && memberOfMemory(resource.data);
      allow create: if isAuth()
        && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isAuth()
        && memberOfMemory(resource.data)
        && memberOfMemory(request.resource.data);
      allow delete: if isAuth() && memberOfMemory(resource.data);
    }

    // ── Books (histoires IA, legacy) ────────────────────────────────────────
    match /books/{bookId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ── Generated books (historique des PDF générés) ─────────────────────────
    match /generatedBooks/{bookId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ── Users (profil + abonnement) ─────────────────────────────────────────
    match /users/{userId} {
      // Lecture par tout utilisateur connecté : nécessaire pour retrouver un
      // compte par email lors du partage et afficher les collaborateurs.
      allow read: if isAuth();

      // subscriptionTier ne peut être écrit que par le backend (Admin SDK)
      // ou l'admin — jamais par l'utilisateur lui-même.
      allow create: if isAuth() && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['subscriptionTier']);
      allow update: if isAdmin() || (
        isAuth() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['subscriptionTier'])
      );
      allow delete: if isAdmin();
    }

    // ── Orders ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      // Statut et notes gérés par l'admin uniquement
      allow update, delete: if isAdmin();
    }

    // ── Legacy : children ───────────────────────────────────────────────────
    match /children/{childId} {
      allow create: if isAuth()
        && request.resource.data.parentId == request.auth.uid;
      allow read, update, delete: if isAuth()
        && resource.data.parentId == request.auth.uid;
    }

    // ── Legacy : milestones (liées par childId) ─────────────────────────────
    match /milestones/{milestoneId} {
      allow create: if isAuth() && ownsChild(request.resource.data.childId);
      allow read, update, delete: if isAuth() && ownsChild(resource.data.childId);
    }

    // aiUsage/{uid} : géré exclusivement par le backend (Admin SDK).
    // Aucune règle = accès client refusé par défaut.
  }
}
